<!DOCTYPE html>
<html lang="fa" dir="rtl" id="html-root">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>WoodCalc Pro v2.0</title>
<style>
@import url('https://cdn.jsdelivr.net/gh/rastikerdar/vazir-font@v30.1.0/Vazir-Regular.css');
@import url('https://cdn.jsdelivr.net/gh/rastikerdar/vazir-font@v30.1.0/Vazir-Bold.css');
:root{
  --p:#6B4423;--pd:#4A2C14;--pl:#F5EDD8;--pll:#FDF8F0;
  --a:#556B2F;--al:#EAF0DC;
  --b:#5B7FA6;--bl:#EAF0FA;
  --t:#8B6F47;--o:#C07A2A;
  --r:#c0392b;--rl:#fdecea;
  --bg:#F5EDD8;--card:#FFFDF8;--br:#E2D0B8;
  --tx:#2C1A0A;--mu:#9A7B5A;--su:#6B4C2A;
  --input-bg:#FFF9F0;--shadow:0 2px 10px rgba(107,68,35,.1);
  --grad:linear-gradient(135deg,#4A2C14,#6B4423);
}
.theme-dark{--bg:#1C1208;--card:#2A1A0A;--br:#3D2510;--tx:#F0E0C0;--mu:#9A7060;--su:#C0A070;--pl:#2A1A0A;--pll:#1C1208;--input-bg:#3D2510}
.theme-walnut{--p:#6B4423;--pd:#4A2C14;--bg:#F5EDD8;--card:#FFFDF8}
.theme-olive{--p:#556B2F;--pd:#3A4A1F;--pl:#EAF0DC;--bg:#EFF5E8;--card:#FAFFF5;--grad:linear-gradient(135deg,#3A4A1F,#556B2F)}
.theme-blue{--p:#1d3557;--pd:#0d1b2a;--pl:#e8f4f8;--bg:#f0f4f8;--card:#fff;--grad:linear-gradient(135deg,#0d1b2a,#1d3557)}
.theme-dark .theme-blue{--bg:#0d1b2a}
.theme-walnutdark{--p:#C08A52;--pd:#3D2510;--bg:#241608;--card:#3D2510;--br:#5A3A1E;--tx:#F0DCC0;--mu:#B08860;--su:#D8B888;--pl:#3D2510;--pll:#241608;--input-bg:#4A2E15;--grad:linear-gradient(135deg,#241608,#5A3A1E)}
.theme-olivedark{--p:#8FAE5E;--pd:#2A3315;--bg:#1A2210;--card:#2A3315;--br:#3E4A22;--tx:#E5EDD5;--mu:#9AAE7A;--su:#C5DBA0;--pl:#2A3315;--pll:#1A2210;--input-bg:#34401C;--grad:linear-gradient(135deg,#1A2210,#3E4A22)}
.theme-naturalwood{--p:#A47148;--pd:#7A5230;--bg:#EDE0CC;--card:#FBF6EC;--br:#D9C7A6;--tx:#3A2A18;--mu:#9D8260;--su:#6E4F30;--pl:#E8D8B8;--pll:#F5EEDD;--input-bg:#FFFBF2;--grad:linear-gradient(135deg,#7A5230,#A47148)}
.theme-blackpro{--p:#C9A24B;--pd:#0A0A0A;--bg:#0E0E0E;--card:#1A1A1A;--br:#2E2E2E;--tx:#EDEDED;--mu:#8A8A8A;--su:#C9A24B;--pl:#1A1A1A;--pll:#0E0E0E;--input-bg:#1F1F1F;--grad:linear-gradient(135deg,#0A0A0A,#262626)}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Vazir','Segoe UI',Tahoma,Arial,sans-serif;background:var(--bg);direction:rtl;min-height:100vh;color:var(--tx);overflow-x:hidden}
.app{max-width:480px;margin:0 auto;position:relative}

/* ===== SPLASH ===== */
#splash{position:fixed;inset:0;background:var(--grad);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity .5s ease}
#splash.hide{opacity:0;pointer-events:none}
.splash-logo{width:130px;height:130px;object-fit:contain;animation:splashPop .6s ease}
.splash-title{color:#fff;font-size:26px;font-weight:800;letter-spacing:1px;animation:splashFade .8s .2s both}
.splash-sub{color:#E8D2B5;font-size:15px;animation:splashFade .8s .4s both}
.splash-dev{color:#C8A880;font-size:12px;animation:splashFade .8s .5s both}
.splash-ver{background:rgba(255,255,255,.15);color:#fff;font-size:11px;padding:4px 12px;border-radius:20px;margin-top:4px;animation:splashFade .8s .6s both}
@keyframes splashPop{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes splashFade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* ===== HEADER ===== */
.hdr{background:var(--grad);padding:12px 14px;position:sticky;top:0;z-index:200;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,.25)}
.hdr-icon{background:rgba(255,255,255,.15);border:none;color:#fff;font-size:19px;width:36px;height:36px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .2s;position:relative}
.hdr-icon:active{background:rgba(255,255,255,.3)}
.hdr-center{display:flex;align-items:center;justify-content:center;gap:9px;flex:1}
.hdr-logo{height:34px;width:34px;object-fit:contain}
.hdr-title{display:flex;flex-direction:column;align-items:center}
.hdr-title h1{font-size:15px;color:#fff;font-weight:800;line-height:1.1}
.hdr-title p{font-size:9px;color:#E8D2B5;margin-top:1px}

/* ===== LANG DROPDOWN ===== */
.lang-dropdown{position:absolute;top:44px;right:0;background:var(--card);border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.25);z-index:500;min-width:170px;overflow:hidden;animation:fadeDD .15s ease}
.lang-dropdown.hidden{display:none}
@keyframes fadeDD{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.lang-header{padding:9px 14px 6px;font-size:11px;color:var(--mu);font-weight:600;border-bottom:1px solid var(--br)}
.lang-item{display:flex;align-items:center;gap:9px;padding:11px 14px;cursor:pointer;font-size:14px;color:var(--tx);transition:background .15s}
.lang-item:hover,.lang-item.active{background:var(--pl);color:var(--p);font-weight:700}

/* ===== SETTINGS DRAWER ===== */
.sett-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:400}.sett-overlay.hidden{display:none}
.sett-drawer{position:fixed;top:0;right:0;width:88%;max-width:340px;height:100%;background:var(--card);overflow-y:auto;padding-bottom:50px;z-index:401;animation:slideInSett .2s ease}
[dir=ltr] .sett-drawer{right:auto;left:0}
.sett-drawer.hidden{display:none}
@keyframes slideInSett{from{transform:translateX(100%)}to{transform:translateX(0)}}
.sett-hdr{background:var(--grad);padding:14px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:1}
.sett-hdr h2{color:#fff;font-size:15px;font-weight:700}
.sett-close{background:rgba(255,255,255,.2);border:none;color:#fff;width:30px;height:30px;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.sett-body{padding:12px}
.sett-sec{background:var(--pll);border-radius:12px;padding:12px;margin-bottom:10px;border:1px solid var(--br)}
.sett-sec-title{font-size:12px;font-weight:700;color:var(--p);margin-bottom:10px}

/* ===== TABS ===== */
.tabs{display:flex;background:var(--card);border-bottom:2px solid var(--br);position:sticky;top:60px;z-index:99;overflow-x:auto;box-shadow:var(--shadow)}
.tb{flex:1;padding:11px 4px;border:none;background:none;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;color:var(--mu);border-bottom:2.5px solid transparent;margin-bottom:-2px;white-space:nowrap;min-width:54px;display:inline-flex;align-items:center;justify-content:center;gap:4px;transition:color .2s}
.tb.active{color:var(--p);font-weight:700;border-bottom-color:var(--p)}
.tb:nth-child(1) span:first-child,.tb:nth-child(2) span:first-child{font-size:13px}
#HC{font-size:10px;opacity:.75;background:var(--p);color:#fff;border-radius:8px;padding:0 5px;font-weight:700}
.cnt{padding:10px 10px 90px}

/* ===== CARDS ===== */
.card{background:var(--card);border-radius:14px;padding:14px 13px 12px;margin-bottom:12px;box-shadow:var(--shadow);border-top:3px solid var(--p)}
.ct{font-size:15px;font-weight:700;color:var(--tx);margin-bottom:10px;display:flex;align-items:center;gap:6px;font-family:'Vazir Bold','Vazir',sans-serif;}
.fld{margin-bottom:9px}
.fld label{display:block;font-size:11px;color:var(--su);margin-bottom:3px;font-weight:600}
.fr{display:flex;align-items:center;gap:5px}.fr input,.fr select{flex:1}
.fu{font-size:11px;color:var(--mu);min-width:38px;white-space:nowrap}
input,select{width:100%;padding:8px 10px;border-radius:9px;border:1.5px solid var(--br);background:var(--input-bg);font-size:13px;color:var(--tx);outline:none;font-family:inherit;direction:rtl;transition:border-color .2s}
input:disabled,select:disabled,button:disabled{opacity:.45;cursor:not-allowed;filter:grayscale(.4)}
input:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(107,68,35,.1)}
.ltr{direction:ltr;text-align:right}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:8px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:5px;margin-bottom:7px}
.sb{padding:8px 4px;border-radius:9px;border:none;background:var(--pl);color:var(--tx);font-weight:500;font-size:12px;cursor:pointer;font-family:inherit;transition:all .2s;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.sb:active{transform:scale(.97)}.sb.sa{background:var(--a);color:#fff;font-weight:700}.sb.sb2{background:var(--p);color:#fff;font-weight:700}.sb.sc{background:var(--b);color:#fff;font-weight:700}.sb.ss{border:2px solid var(--p);background:var(--pl);color:var(--p);font-weight:700}.sb.ss.sb2{background:var(--p);color:#fff}
.bl{width:100%;padding:8px 12px;border-radius:9px;border:none;background:var(--pl);color:var(--tx);text-align:right;font-family:inherit;font-size:12px;cursor:pointer;margin-bottom:5px;display:block;transition:all .2s}
.bl:active{transform:scale(.98)}.bl.act{background:var(--p);color:#fff}
.bd{width:100%;padding:8px;border-radius:9px;border:1.5px dashed var(--mu);background:transparent;color:var(--su);font-size:12px;cursor:pointer;font-family:inherit;font-weight:600;margin-top:3px}.bd.act{background:var(--pl)}
.badd{width:100%;margin-top:8px;padding:10px;background:var(--a);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;transition:opacity .2s}
.badd:active{opacity:.8}
.bsave{width:100%;margin-top:10px;padding:12px;background:var(--p);color:#fff;border:none;border-radius:11px;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer}
.bcalc{width:100%;padding:14px;background:var(--b);color:#fff;border:none;border-radius:11px;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;margin-bottom:12px;box-shadow:0 4px 15px rgba(91,127,166,.4);letter-spacing:.5px}
.brem{background:none;border:none;color:var(--r);font-size:18px;cursor:pointer;padding:0 8px;font-weight:bold}
.bshr{background:var(--a);color:#fff;border:none;border-radius:10px;padding:9px;font-size:13px;font-family:inherit;cursor:pointer;margin-top:8px;width:100%}
.pab{background:var(--pll);border-radius:11px;padding:10px;border:1.5px dashed var(--br);margin-top:8px}
.sl{font-size:10px;color:var(--su);margin-bottom:2px}
.rr{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--br)}
.rl{font-size:12px;color:var(--su)}.rv{font-size:12px;color:var(--tx);font-weight:500}
.rr.bold .rl{color:var(--tx);font-weight:700;font-size:14px}.rr.bold .rv{color:var(--p);font-weight:800;font-size:14px}
.rr.rsec{background:var(--pl);margin:3px -4px;padding:3px 8px;border-radius:5px;border:none}.rr.rsec .rl{color:var(--p);font-weight:700;font-size:11px}
.rr.vat{background:#fff3e0}.rr.vat .rl,.rr.vat .rv{color:var(--o)}
.rr.disc{background:#eafff0}.rr.disc .rl,.rr.disc .rv{color:var(--a)}

/* RESULT BOX */
.result-final{background:var(--grad);border-radius:14px;padding:18px;margin:12px 0 8px;text-align:center;box-shadow:0 6px 20px rgba(107,68,35,.35)}
.result-final.result-final-secondary{background:var(--card);border:2px dashed var(--br);box-shadow:none;padding:14px;margin-top:-2px;}
.result-final.result-final-secondary .lbl{color:var(--su)!important;font-size:12px;}
.result-final.result-final-secondary .amt{color:var(--tx)!important;font-size:20px;}
.result-final .lbl{color:#E8D2B5;font-size:13px;margin-bottom:6px}
.result-final .amt{color:#fff;font-size:28px;font-weight:800;letter-spacing:.5px}
.result-final .sub{color:#C8A880;font-size:11px;margin-top:4px}
.result-vol{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.result-vol-item{flex:1;min-width:75px;background:var(--al);border-radius:10px;padding:9px 6px;text-align:center;border:1px solid #C8DC9A}
.result-vol-item .v{font-size:14px}
.result-vol-item .v{font-size:16px;font-weight:800;color:var(--a)}
.result-vol-item .l{font-size:10px;color:var(--su);margin-top:2px}

.hi{background:var(--card);border-radius:13px;padding:12px;margin-bottom:10px;box-shadow:var(--shadow);border-right:4px solid var(--p);cursor:pointer}
[dir=ltr] .hi{border-right:none;border-left:4px solid var(--p)}
.hih{display:flex;justify-content:space-between;align-items:flex-start}
.hin{font-weight:700;font-size:13px;color:var(--tx)}.him{font-size:11px;color:var(--mu);margin-top:2px}
.hit{margin-top:8px;padding:7px 10px;background:var(--pl);border-radius:9px;font-size:14px;font-weight:800;color:var(--p)}
.hex{display:none;margin-top:8px;border-top:1px solid var(--br);padding-top:8px}.hex.open{display:block}
.hact{display:flex;gap:6px;margin-top:8px}
.bpdf{flex:1;padding:9px;background:var(--r);color:#fff;border:none;border-radius:9px;font-size:12px;font-family:inherit;cursor:pointer;font-weight:600}
.bedt{flex:1;padding:9px;background:var(--b);color:#fff;border:none;border-radius:9px;font-size:12px;font-family:inherit;cursor:pointer;font-weight:600}
.bcopy{flex:1;padding:9px;background:var(--a);color:#fff;border:none;border-radius:9px;font-size:12px;font-family:inherit;cursor:pointer;font-weight:600}
.bshare2{flex:1;padding:9px;background:var(--b);color:#fff;border:none;border-radius:9px;font-size:12px;font-family:inherit;cursor:pointer;font-weight:600}
.blbl{flex:0 0 44px;padding:9px;background:var(--t);color:#fff;border:none;border-radius:9px;font-size:13px;font-family:inherit;cursor:pointer;font-weight:600}
.status-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:10px;white-space:nowrap}
.status-badge-select{font-size:10px;font-weight:700;padding:3px 7px;border-radius:10px;white-space:nowrap;border:none;width:auto;-webkit-appearance:none;appearance:none;cursor:pointer;font-family:inherit}
.status-filter-chip{background:var(--pl);border:1.5px solid var(--br);border-radius:20px;padding:6px 12px;font-size:11px;font-weight:600;color:var(--tx);cursor:pointer;font-family:inherit;transition:all .15s}
.status-filter-chip.active{background:var(--p);color:#fff;border-color:var(--p)}
/* Template selector cards + CSS-mockup thumbnails (no server-rendered previews needed) */
.tmpl-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.tmpl-card-opt{position:relative;border:2px solid var(--br);border-radius:12px;padding:8px;cursor:pointer;text-align:center;background:var(--card);transition:border-color .15s}
.tmpl-card-opt.act{border-color:var(--p);box-shadow:0 0 0 2px rgba(107,68,35,.15)}
.tmpl-card-opt.locked{opacity:.55}
.tmpl-card-name{font-size:11px;font-weight:700;color:var(--tx);margin-top:6px}
.tmpl-lock-badge{position:absolute;top:4px;left:4px;background:rgba(0,0,0,.6);color:#fff;font-size:10px;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center}
.tmpl-thumb{width:100%;height:78px;border-radius:6px;overflow:hidden;position:relative;background:#fff;border:1px solid #eee}
.tmpl-thumb-professional .t-hdr{height:16px;background:linear-gradient(90deg,#4A2C14,#6B4423)}
.tmpl-thumb-professional .t-logo{position:absolute;top:3px;left:4px;width:9px;height:9px;border-radius:50%;background:#D4AF37}
.tmpl-thumb-professional .t-row{height:6px;margin:5px 7px;background:#F5EDD8;border-radius:2px}
.tmpl-thumb-professional .t-row.gold{background:#D4AF37;width:55%}
.tmpl-thumb-minimal{padding-top:6px}
.tmpl-thumb-minimal .t-line{height:2px;margin:7px 9px;background:#e8e8e8}
.tmpl-thumb-minimal .t-line.dark{background:#333;width:38%;height:4px;margin-top:10px}
.tmpl-thumb-moderncard{background:#eef3f9}
.tmpl-thumb-moderncard .t-card{position:absolute;top:9px;left:9px;right:9px;bottom:9px;background:#fff;border-radius:9px;box-shadow:0 3px 7px rgba(0,0,0,.13)}
.tmpl-thumb-moderncard .t-dot{position:absolute;top:8px;left:8px;width:8px;height:8px;border-radius:50%;background:#5B8DEF}
.tmpl-thumb-moderncard .t-bar{position:absolute;bottom:8px;left:8px;right:8px;height:13px;background:#E8F0FE;border-radius:6px}
.tmpl-thumb-receipt{background:#fafafa;display:flex;justify-content:center;align-items:flex-start}
.tmpl-thumb-receipt .t-strip{width:36px;height:70px;background:#fff;border:1px dashed #aaa;margin-top:4px;padding:5px 3px}
.tmpl-thumb-receipt .t-tline{height:2px;background:#555;margin:3px 0}
.stats-dash{background:var(--grad);border-radius:14px;padding:16px 10px;margin-bottom:14px;display:flex;gap:6px;box-shadow:var(--shadow)}
.stats-dash .sd-item{flex:1;text-align:center}
.stats-dash .sd-v{color:#fff;font-size:15px;font-weight:800}
.stats-dash .sd-l{color:#E8D2B5;font-size:9.5px;margin-top:3px}
.er{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--br)}.el{font-size:11px;color:var(--su)}.ev{font-size:11px;color:var(--tx);font-weight:500}
.es{font-size:11px;color:var(--p);font-weight:700;margin:6px 0 2px}
.emp{text-align:center;padding:50px 20px;color:var(--mu)}
.ib{font-size:11px;padding:5px 9px;border-radius:7px;margin-top:3px}.ig{color:var(--a);background:var(--al)}.ibl{color:var(--b);background:var(--bl)}.ib2{color:var(--p);font-size:10px;margin-top:3px}
.ss2{font-size:11px;font-weight:700;color:var(--b);margin-bottom:5px}.ss3{font-size:11px;font-weight:700;color:var(--p);margin-bottom:5px}
.hidden{display:none}
.wsc{background:var(--pll);border-radius:11px;padding:10px;margin-bottom:8px;border:1.5px solid var(--br)}
.wsh{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.wsn{background:var(--p);color:#fff;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.wst{font-size:12px;font-weight:700;color:var(--p);margin-right:7px}
.awb{width:100%;padding:10px;border-radius:11px;border:2px dashed var(--p);background:var(--card);color:var(--p);font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;margin-top:4px;transition:background .2s}
.awb:hover{background:var(--pl)}
.pi{display:flex;justify-content:space-between;align-items:center;padding:6px 8px;background:var(--card);border-radius:8px;margin-bottom:5px;border:1px solid var(--br)}
.pn2{font-weight:700;font-size:13px;color:var(--tx)}.pq2{font-size:12px;color:var(--p);font-weight:700;margin-right:5px}.pd2{font-size:10px;color:var(--mu);margin-top:2px}
.sb2inp{display:flex;gap:6px;margin-bottom:10px}.sb2inp input{flex:1}
.ocr{display:grid;grid-template-columns:1fr 1fr auto;gap:5px;margin-bottom:5px;align-items:center}
.thb{width:34px;height:34px;border-radius:50%;border:3px solid transparent;cursor:pointer;margin:3px;transition:transform .15s}.thb.sel{border-color:var(--tx);transform:scale(1.15)}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#2C1A0A;color:#F5EDD8;padding:10px 20px;border-radius:22px;font-size:13px;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap}.toast.show{opacity:1}
.bank-picker-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1000;display:flex;align-items:flex-end;justify-content:center}
.bank-picker-overlay.hidden{display:none}
.bank-picker-box{background:var(--card);width:100%;max-width:480px;max-height:75vh;border-radius:18px 18px 0 0;display:flex;flex-direction:column;overflow:hidden;animation:slideUp .25s ease}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.bank-picker-hdr{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--br)}
.bank-picker-close{background:none;border:none;font-size:18px;color:var(--mu);cursor:pointer;padding:4px 8px}
.bank-picker-list{overflow-y:auto;padding:10px 12px;flex:1}
.bank-pick-item{display:flex;justify-content:space-between;align-items:center;background:var(--pll);border:1px solid var(--br);border-radius:10px;padding:10px 12px;margin-bottom:8px;cursor:pointer;transition:all .15s}
.bank-pick-item:active{transform:scale(.98);background:var(--pl)}
.lb{flex:1;padding:8px;border-radius:9px;border:1.5px solid var(--br);background:var(--pl);color:var(--tx);font-family:inherit;font-size:13px;cursor:pointer;transition:all .2s}.lb.act{background:var(--p);color:#fff;font-weight:700;border-color:var(--p)}
.pc-box{